{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "addLabels": [
    "renovate"
  ],
  "automergeStrategy": "rebase",
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [
        "^.*docker-compose\\.json$"
      ],
      "matchStrings": [
        "\"image\": \"(?<depName>.*?):(?<currentValue>.*?)\","
      ],
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "automerge": false
    },
    {
      "matchDepTypes": [
        "devDependencies"
      ],
      "automerge": false
    },
    {
      "description": "Backing services are pinned to the version each upstream app expects; do not auto-update them. Docker datasource reports names with a registry/namespace prefix (e.g. docker.io/postgres, postgis/postgis, getmeili/meilisearch), so match on a trailing path segment.",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "/(^|/)(mariadb|mysql|mongodb|postgres|postgis|redis|meilisearch)$/"
      ],
      "enabled": false
    }
  ],
  "postUpgradeTasks": {
    "commands": [
      "bun ./scripts/update-config.ts {{packageFile}} {{newVersion}}",
      "bun install && bun run test"
    ],
    "fileFilters": [
      "**/*"
    ],
    "executionMode": "update"
  }
}
